{
  "name": "classified-ads-marketplace",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "dev": "concurrently -k \"npm run dev:backend\" \"npm run dev:frontend\" \"npm run dev:socket\"",
    "dev:socket": "node socket-server.js",
    "dev:frontend": "next dev -p 3000",
    "dev:backend": "cd /d \"backend\" && php artisan serve --port=8000",
    "dev:simple": "next dev -p 3000",
    "build": "next build",
    "start": "next start",
    "start:prod": "npm run build && next start",
    "start:socket": "node socket-server.js",
    "start:all": "concurrently -k \"npm run start:socket\" \"npm run start\"",
    "pm2:start": "pm2 start ecosystem.config.js",
    "pm2:stop": "pm2 stop ecosystem.config.js",
    "pm2:restart": "pm2 restart ecosystem.config.js",
    "pm2:logs": "pm2 logs",
    "pm2:status": "pm2 status",
    "clean": "rmdir /s /q .next 2>nul || true",
    "lint": "next lint"
  },
  "dependencies": {
    "@tanstack/react-query": "^5.100.14",
    "axios": "^1.13.6",
    "cloudinary": "^2.9.0",
    "clsx": "^2.1.1",
    "framer-motion": "^12.38.0",
    "jspdf": "^4.2.1",
    "jspdf-autotable": "^5.0.8",
    "lucide-react": "^0.577.0",
    "next": "^14.2.0",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "react-hot-toast": "^2.6.0",
    "recharts": "^3.8.0",
    "sharp": "^0.34.5",
    "socket.io": "^4.8.3",
    "socket.io-client": "^4.8.3",
    "swr": "^2.4.1",
    "zustand": "^5.0.11"
  },
  "devDependencies": {
    "@types/node": "^20.11.0",
    "@types/react": "^18.2.0",
    "@types/react-dom": "^18.2.0",
    "autoprefixer": "^10.4.0",
    "concurrently": "^8.2.2",
    "eslint": "^8.57.1",
    "eslint-config-next": "^14.2.35",
    "postcss": "^8.4.0",
    "tailwindcss": "^3.4.0",
    "typescript": "^5.3.0"
  }
}
