APP_NAME=iList
APP_ENV=production
APP_DEBUG=false
APP_URL=http://localhost:8000

DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=classified_marketplace
DB_USERNAME=root
DB_PASSWORD=

# Use Redis for cache in production (much faster than database/file)
CACHE_STORE=redis
REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

# Queue connection
QUEUE_CONNECTION=database

# Session
SESSION_DRIVER=file

# Mail
MAIL_MAILER=smtp
MAIL_HOST=smtp.gmail.com
MAIL_PORT=587
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_ENCRYPTION=tls
MAIL_FROM_ADDRESS="hello@ilist.ng"
MAIL_FROM_NAME="${APP_NAME}"

# Cloudinary
CLOUDINARY_CLOUD_NAME=your-cloud-name
CLOUDINARY_API_KEY=your-api-key
CLOUDINARY_API_SECRET=your-api-secret
CLOUDINARY_FOLDER=classified-ads

# Paystack
PAYSTACK_PUBLIC_KEY=your-public-key
PAYSTACK_SECRET_KEY=your-secret-key
PAYSTACK_MERCHANT_EMAIL=your-email

# Sanctum
SANCTUM_STATEFUL_DOMAINS=localhost:3000,localhost:8080
SESSION_DOMAIN=localhost

# Socket.IO
SOCKET_URL=http://localhost:3006
SOCKET_PORT=3006

# Frontend URL
FRONTEND_URL=http://localhost:3000

# Admin
ADMIN_IP_WHITELIST=127.0.0.1,::1
