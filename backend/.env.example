APP_NAME=iList
APP_ENV=production
APP_DEBUG=false
APP_URL=http://localhost:8000

DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=classified_marketplace
DB_USERNAME=root
DB_PASSWORD=

# ============================================
# CACHE - Use Redis for production
# ============================================
CACHE_STORE=redis
REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

# ============================================
# QUEUE - Use Redis for production (NOT database)
# ============================================
QUEUE_CONNECTION=redis
REDIS_QUEUE=default
REDIS_QUEUE_CONNECTION=default

# ============================================
# SESSION
# ============================================
SESSION_DRIVER=redis
SESSION_CONNECTION=default
SESSION_LIFETIME=1440
SESSION_COOKIE=ilist_session

# ============================================
# MEILISEARCH - Instant search engine
# ============================================
MEILISEARCH_HOST=http://127.0.0.1:7700
MEILISEARCH_KEY=
MEILISEARCH_INDEX=ads

# ============================================
# CDN / EDGE CACHING
# ============================================
CDN_PROVIDER=cloudflare
CDN_DISTRIBUTION_ID=
CDN_ZONE_ID=
CDN_API_KEY=
CDN_EMAIL=
CDN_URL=
FASTLY_SERVICE_ID=

# ============================================
# MONITORING
# ============================================
SLOW_QUERY_THRESHOLD_MS=200
ENABLE_REQUEST_LOGGING=true
ENABLE_SLOW_QUERY_LOG=true
MONITORING_METRICS_TTL=86400

# ============================================
# SECURITY / ANTI-ABUSE
# ============================================
MAX_ADS_PER_DAY=10
MAX_ADS_PER_HOUR=5
MAX_ADS_SAME_CATEGORY_PER_DAY=3
MIN_SECONDS_BETWEEN_ADS=60
MAX_BOOSTS_PER_DAY=5
MAX_BOOST_AMOUNT_PER_DAY=100000
MAX_MESSAGES_PER_MINUTE=20
RATE_LIMIT_GLOBAL=300
RATE_LIMIT_GLOBAL_GUEST=100

# ============================================
# MAIL
# ============================================
MAIL_MAILER=smtp
MAIL_HOST=smtp.gmail.com
MAIL_PORT=587
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_ENCRYPTION=tls
MAIL_FROM_ADDRESS="hello@ilist.ng"
MAIL_FROM_NAME="${APP_NAME}"

# ============================================
# CLOUDINARY
# ============================================
CLOUDINARY_CLOUD_NAME=your-cloud-name
CLOUDINARY_API_KEY=your-api-key
CLOUDINARY_API_SECRET=your-api-secret
CLOUDINARY_FOLDER=classified-ads

# ============================================
# PAYSTACK
# ============================================
PAYSTACK_PUBLIC_KEY=your-public-key
PAYSTACK_SECRET_KEY=your-secret-key
PAYSTACK_MERCHANT_EMAIL=your-email

# ============================================
# SANCTUM / AUTH
# ============================================
SANCTUM_STATEFUL_DOMAINS=localhost:3000,localhost:8080
SESSION_DOMAIN=localhost

# ============================================
# SOCKET.IO
# ============================================
SOCKET_URL=http://localhost:3006
SOCKET_PORT=3006

# ============================================
# FRONTEND
# ============================================
FRONTEND_URL=http://localhost:3000
NEXT_PUBLIC_API_URL=http://localhost:8000/api
NEXT_PUBLIC_SOCKET_URL=http://localhost:3006
NEXT_PUBLIC_CLOUDINARY_CLOUD_NAME=dcklcvihq
NEXT_PUBLIC_PAYSTACK_KEY=pk_test_1fa632552fc39b32dcad803cb08a04d9ac5d3fe9

# ============================================
# TEMPORARY UPLOADS
# ============================================
TEMP_UPLOAD_LIFETIME_HOURS=24

# ============================================
# ADMIN SECURITY
# ============================================
ADMIN_IP_WHITELIST=127.0.0.1,::1
ADMIN_SESSION_TIMEOUT=15
ADMIN_SECRET_KEY_HASH=
ADMIN_RATE_LIMIT_ATTEMPTS=5
ADMIN_RATE_LIMIT_DECAY=15
ADMIN_ALLOWED_IPS=127.0.0.1,::1
ADMIN_ALERT_ON_SUSPICIOUS=true
ADMIN_BLOCK_VPN_PROXY=false
ADMIN_MAX_FAILED_ATTEMPTS=10
