# ── Frontend Environment (copy to .env.local) ──
NEXT_PUBLIC_API_URL=http://127.0.0.1:8000/api
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_SOCKET_URL=http://localhost:3006
NEXT_PUBLIC_CLOUDINARY_CLOUD_NAME=your_cloud_name
NEXT_PUBLIC_ENABLE_IMAGE_OPTIMIZATION=true
NEXT_PUBLIC_ENABLE_COMPRESSION=true
NEXT_PUBLIC_ADS_PER_PAGE=12
NEXT_PUBLIC_GOOGLE_CLIENT_ID=your_google_client_id

# ── AI Description Generation (Admin) ──
# Get a key at https://platform.openai.com/api-keys
# OPENAI_API_KEY=sk-your-key-here
