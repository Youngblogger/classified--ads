# Supabase Production Environment
# Copy to .env.production and fill in real values
# NEVER commit real credentials to Git

NEXT_PUBLIC_SUPABASE_URL=https://<production-project-ref>.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=<production-anon-key>

# Used by CI/CD pipeline (set as GitHub Secrets):
# PRODUCTION_SUPABASE_PROJECT_REF=<production-project-ref>
# SUPABASE_ACCESS_TOKEN=<personal-access-token>
